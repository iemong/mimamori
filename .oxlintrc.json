{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "complexity": "error",
    "max-depth": "error",
    "max-lines": ["error", { "max": 450 }],
    "max-lines-per-function": "error",
    "max-params": "error",
    "max-nested-callbacks": "error",
    "max-statements": "error"
  },
  "overrides": [
    {
      "files": ["scripts/**"],
      "rules": {
        "complexity": "off",
        "max-depth": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-params": "off",
        "max-nested-callbacks": "off",
        "max-statements": "off"
      }
    },
    {
      "files": ["src/__tests__/**"],
      "rules": {
        "complexity": "off",
        "max-depth": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-params": "off",
        "max-nested-callbacks": "off",
        "max-statements": "off"
      }
    }
  ]
}
